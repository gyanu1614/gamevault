# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-project-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your-key
STRIPE_SECRET_KEY=sk_test_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron Job Security
CRON_SECRET=your-cron-secret-key-here

# Trustpilot
NEXT_PUBLIC_TRUSTPILOT_BUSINESS_UNIT_ID=your-business-unit-id
TRUSTPILOT_API_KEY=your-trustpilot-api-key

# Transactional email (Resend) — domain must be verified in the Resend dashboard
RESEND_API_KEY=

# Trustpilot (free plan: Review Collector widget + BCC auto-invitations)
TRUSTPILOT_BCC_EMAIL=
